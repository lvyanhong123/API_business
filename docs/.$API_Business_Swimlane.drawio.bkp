            <mxPoint x="100" y="240" as="sourcePoint"/>
            <mxPoint x="1100" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="grid-h2" style="endArrow=none;dashed=1;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="360" as="sourcePoint"/>
            <mxPoint x="1100" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="grid-h3" style="endArrow=none;dashed=1;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="480" as="sourcePoint"/>
            <mxPoint x="1100" y="480" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 流程节点 -->
        <!-- 线下签约行 -->
        <mxCell id="step-1" value="商务洽谈" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="130" y="150" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-6" value="签订合同" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4CAF50;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="350" y="150" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-2" value="打款" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="130" y="210" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-7" value="录入收款" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="550" y="150" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- 线上购买行 -->
        <mxCell id="step-3" value="选购产品" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="130" y="270" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-4" value="下单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="130" y="330" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-10" value="审核订单" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9C27B0;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="750" y="270" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- API交付行 -->
        <mxCell id="step-11" value="获得配额" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#607D8B;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="950" y="390" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-12" value="使用API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#607D8B;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="550" y="390" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- 结算行 -->
        <mxCell id="step-8" value="对账确认" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="550" y="510" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-5" value="对账确认" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="130" y="510" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step-9" value="退款处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="550" y="570" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- 结束节点 -->
        <mxCell id="end-1" value="结束" style="ellipse;whiteSpace=wrap;html=1;fillColor=#F44336;fontColor=#FFFFFF" vertex="1" parent="1">
          <mxGeometry x="750" y="570" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- 连接线 -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-1" target="step-6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-6" target="step-2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-2" target="step-7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-7" target="step-3">
