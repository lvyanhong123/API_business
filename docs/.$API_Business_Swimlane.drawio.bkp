<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="API业务泳道图" id="api-business-flow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="title" value="API业务平台 - 核心业务流程泳道图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- 列头：角色 -->
        <mxCell id="col-customer" value="客户" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=14;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="col-sales" value="商务/销售" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=14;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="300" y="80" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="col-finance" value="财务" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=14;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="col-ops" value="平台运营" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=14;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="col-system" value="系统" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=14;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="900" y="80" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- 行头：阶段 -->
        <mxCell id="row-1" value="线下签约" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#666666;fillColor=#F5F5F5;strokeColor=#CCCCCC" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="1000" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="row-2" value="线上购买" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#666666;fillColor=#F5F5F5;strokeColor=#CCCCCC" vertex="1" parent="1">
          <mxGeometry x="100" y="240" width="1000" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="row-3" value="API交付" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#666666;fillColor=#F5F5F5;strokeColor=#CCCCCC" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="1000" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="row-4" value="结算" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#666666;fillColor=#F5F5F5;strokeColor=#CCCCCC" vertex="1" parent="1">
          <mxGeometry x="100" y="480" width="1000" height="120" as="geometry"/>
        </mxCell>

        <!-- 网格分隔线 - 垂直线 -->
        <mxCell id="grid-v1" style="endArrow=none;dashed=1;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="120" as="sourcePoint"/>
            <mxPoint x="300" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="grid-v2" style="endArrow=none;dashed=1;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="120" as="sourcePoint"/>
            <mxPoint x="500" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="grid-v3" style="endArrow=none;dashed=1;html=1;strokeColor=#CCCCCC;strokeWidth=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="700" y="120" as="sourcePoint"/>
            <mxPoint x="700" y="600" as="targetPoint"/>
