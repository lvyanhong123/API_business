        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-3" target="step-4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-4" target="step-10">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#4CAF50;strokeWidth=2" edge="1" parent="1" source="step-10" target="step-11">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-11" target="step-12">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-12" target="step-8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#333333;strokeWidth=2" edge="1" parent="1" source="step-8" target="step-5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 续订循环 -->
        <mxCell id="loop-renew" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2196F3;strokeWidth=2;dashed=1" edge="1" parent="1" source="step-5" target="step-3">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="180" y="270" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="80" y="535"/>
              <mxPoint x="80" y="295"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="label-renew" value="续订(循环)" style="text;html=1;align=center;verticalAlign=middle;fontColor=#2196F3;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="80" height="20" as="geometry"/>
        </mxCell>

        <!-- 退款 -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#F44336;strokeWidth=2" edge="1" parent="1" source="step-5" target="step-9">
